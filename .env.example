NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# رمزِ ورودِ سوپرادمین (صفحه‌ی /super)
SUPER_SECRET=
# کلیدِ امضای کوکی‌های ورود — یک رشته‌ی تصادفیِ بلند
AUTH_SECRET=
# درگاهِ پرداختِ آنلاین (زیبال) — بدونِ این، پرداختِ آنلاین با خطای روشن fail می‌شود
ZIBAL_MERCHANT_ID=
# true برای تست بدونِ حسابِ واقعی (از merchant تستیِ خودِ زیبال استفاده می‌کند)
ZIBAL_SANDBOX=
# حالتِ موقتِ پیش‌ازپیامک: true یعنی کدِ OTP در پاسخِ HTTP برمی‌گردد (کدِ تست).
# با اتصالِ پنلِ پیامک این خط باید حذف شود تا کد فقط پیامک شود.
OTP_ECHO_CODE=
