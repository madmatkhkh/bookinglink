NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# رمزِ ورودِ سوپرادمین (صفحه‌ی /super)
SUPER_SECRET=
# کلیدِ امضای کوکی‌های ورود — یک رشته‌ی تصادفیِ بلند
AUTH_SECRET=
# درگاهِ پرداختِ آنلاین (زیبال) — بدونِ این، پرداختِ آنلاین با خطای روشن fail می‌شود
ZIBAL_MERCHANT_ID=
# true برای تست بدونِ حسابِ واقعی (از merchant تستیِ خودِ زیبال استفاده می‌کند)
ZIBAL_SANDBOX=
# حالتِ موقتِ پیش‌ازپیامک: true یعنی کدِ OTP در پاسخِ HTTP برمی‌گردد (کدِ تست).
# با ست‌شدنِ SMS_IR_API_KEY این حالت خودکار غیرفعال می‌شود؛ نیازی به حذفِ دستی نیست.
OTP_ECHO_CODE=
# پیامکِ OTP از طریقِ sms.ir (متدِ send/verify با الگو):
#   ۱) پنلِ sms.ir → برنامه‌نویسان → کلیدِ وب‌سرویس بساز → همان‌جا بریز
#   ۲) پنلِ sms.ir → الگوها → یک الگویِ تاییدیه با پارامترِ «CODE» بساز → شناسه‌اش را اینجا بریز
SMS_IR_API_KEY=
SMS_IR_TEMPLATE_ID=
