NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# رمزِ ورودِ سوپرادمین (صفحه‌ی /super)
SUPER_SECRET=
# کلیدِ امضای کوکی‌های ورود — یک رشته‌ی تصادفیِ بلند
AUTH_SECRET=
# درگاهِ پرداختِ آنلاین (زیبال) — بدونِ این، پرداختِ آنلاین با خطای روشن fail می‌شود
ZIBAL_MERCHANT_ID=
# true برای تست بدونِ حسابِ واقعی (از merchant تستیِ خودِ زیبال استفاده می‌کند)
ZIBAL_SANDBOX=
# حالتِ موقتِ پیش‌ازپیامک: true یعنی کدِ OTP در پاسخِ HTTP برمی‌گردد (کدِ تست).
# با ست‌شدنِ SMS_IR_API_KEY این حالت خودکار غیرفعال می‌شود؛ نیازی به حذفِ دستی نیست.
OTP_ECHO_CODE=
# پیامکِ OTP از طریقِ sms.ir (متدِ send/verify با الگو):
#   ۱) پنلِ sms.ir → برنامه‌نویسان → کلیدِ وب‌سرویس بساز → همان‌جا بریز
#   ۲) پنلِ sms.ir → الگوها → یک الگویِ تاییدیه با پارامترِ «CODE» بساز → شناسه‌اش را اینجا بریز
SMS_IR_API_KEY=
SMS_IR_TEMPLATE_ID=
# الگویِ دومِ sms.ir برایِ «یادآوریِ نوبتِ فردا» — با سه پارامترِ NAME و DATE و TIME
# متنِ پیشنهادی: «یادآوری: نوبتِ شما در %NAME% فردا %DATE% ساعتِ %TIME% است.»
# بدونِ این متغیر، cronِ یادآوری بدونِ خطا رد می‌شود (skip).
SMS_IR_REMINDER_TEMPLATE_ID=
# رمزِ cronِ یادآوری — Vercel با ست‌بودنِ همین نام، هدرِ Authorization را خودش می‌فرستد.
# (Vercel → Settings → Environment Variables → CRON_SECRET، یک رشته‌ی تصادفیِ بلند)
CRON_SECRET=
# دامنه‌ی اصلیِ پلتفرم (بدونِ https)؛ برایِ metadata و تشخیصِ دامنه‌ی اختصاصیِ tenant ها در middleware
PLATFORM_DOMAIN=
# درصدِ کمیسیونِ پلتفرم از پرداخت‌های آنلاین (عدد؛ خالی = 0)
PLATFORM_COMMISSION_PERCENT=
# true = تسهیمِ زیبال (تسویه‌ی مستقیمِ سهمِ دکتر به شبایش)؛ خالی/false = تسویه‌ی دستی
ZIBAL_MULTIPLEXING_ENABLED=
# ایمیل (Resend) — برایِ ورودِ ایمیلی، یادآوریِ ایمیلی، و کمپینِ ایمیلی. بدونِ این
# دو تا، بخش‌هایِ ایمیلی بی‌صدا غیرفعال می‌مانند (کد فقط با OTP_ECHO_CODE قابلِ‌تست است).
RESEND_API_KEY=
EMAIL_FROM=
# پیامکِ آزاد/گروهی (لیستِ انتظار + کمپینِ بازاریابی) — نیازمندِ خطِ اختصاصیِ
# ثبت‌شده در پنلِ sms.ir؛ بدونِ این، پیامکِ آزاد بی‌صدا غیرفعال می‌ماند (فقط
# پیامکِ قالب‌دارِ OTP/یادآوریِ نوبت که از قبل هست، دست‌نخورده کار می‌کند).
SMS_IR_LINE_NUMBER=
